# RealStream Production Environment Variables
# Copy this file to .env on your server and fill in real values.
# Usage: docker compose -f docker-compose.prod.yml --env-file .env up -d

# ─── Database ────────────────────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Auth Service ────────────────────────────────────────────────
# Google OAuth2 credentials (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT token signing secret (generate with: openssl rand -hex 32)
APP_AUTH_TOKEN_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Frontend URL for OAuth2 redirects
FRONTEND_URL=https://realstream.site

# ─── Scraper Service ────────────────────────────────────────────
# YouTube Data API v3 key (from console.cloud.google.com)
YOUTUBE_API_KEY=your-youtube-api-key
